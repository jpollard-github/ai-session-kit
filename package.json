{
  "name": "ai-session-kit",
  "displayName": "AI Session Kit",
  "description": "Bootstrap durable handoffs and living docs for AI coding workflows.",
  "version": "0.5.0",
  "publisher": "local-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpollard-github/ai-session-kit.git"
  },
  "homepage": "https://github.com/jpollard-github/ai-session-kit",
  "icon": "media/ai-session-kit.png",
  "scripts": {
    "lint:extension": "node --check src/extension.js && node -e \"JSON.parse(require('fs').readFileSync('package.json','utf8')); console.log('package.json ok')\"",
    "package:vsix": "mkdir -p vsix && vsce package --out vsix/ai-session-kit-v$npm_package_version.vsix",
    "publish:check": "node scripts/publish-preflight.js",
    "publish:vsix": "npm run publish:check && npm run lint:extension && npm run package:vsix",
    "publish:marketplace": "npm run publish:check && npm run lint:extension && vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.2"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:codexSessionKit.initializeProjectMemoryDocs",
    "onCommand:codexSessionKit.updateMemoryDocsNow",
    "onCommand:codexSessionKit.upgradeAiContextConfigToLatestDefaults",
    "onCommand:codexSessionKit.generateSessionSummary",
    "onCommand:codexSessionKit.openGettingStarted",
    "onCommand:codexSessionKit.openGeneralDocumentation",
    "onCommand:codexSessionKit.validateMemoryDocs",
    "onCommand:codexSessionKit.startSessionFromProjectMemory",
    "onCommand:codexSessionKit.finishSessionAndUpdateProjectMemory",
    "onCommand:codexSessionKit.showProjectMemoryStatus",
    "onView:codexSessionKit.projectMemoryView"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codexSessionKit.initializeProjectMemoryDocs",
        "category": "AI Session",
        "title": "Initialize Handoff Docs"
      },
      {
        "command": "codexSessionKit.startSessionFromProjectMemory",
        "category": "AI Session",
        "title": "Start Session From Handoff Docs"
      },
      {
        "command": "codexSessionKit.updateMemoryDocsNow",
        "category": "AI Session",
        "title": "Prepare Handoff Review"
      },
      {
        "command": "codexSessionKit.upgradeAiContextConfigToLatestDefaults",
        "category": "AI Session",
        "title": "Upgrade AI Context Config To Latest Defaults"
      },
      {
        "command": "codexSessionKit.generateSessionSummary",
        "category": "AI Session",
        "title": "Generate Session Handoff"
      },
      {
        "command": "codexSessionKit.openGettingStarted",
        "category": "AI Session",
        "title": "Open Getting Started"
      },
      {
        "command": "codexSessionKit.openGeneralDocumentation",
        "category": "AI Session",
        "title": "Open General Documentation"
      },
      {
        "command": "codexSessionKit.validateMemoryDocs",
        "category": "AI Session",
        "title": "Validate Memory Docs"
      },
      {
        "command": "codexSessionKit.finishSessionAndUpdateProjectMemory",
        "category": "AI Session",
        "title": "Finish Session And Update Handoff Docs"
      },
      {
        "command": "codexSessionKit.showProjectMemoryStatus",
        "category": "AI Session",
        "title": "Show Handoff Docs Status"
      },
      {
        "command": "codexSessionKit.refreshProjectMemoryView",
        "category": "AI Session",
        "title": "Refresh AI Session View",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codexSessionKit",
          "title": "AI Session",
          "icon": "media/ai-session-kit.svg"
        }
      ]
    },
    "views": {
      "codexSessionKit": [
        {
          "id": "codexSessionKit.projectMemoryView",
          "name": "Session Kit"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "codexSessionKit.refreshProjectMemoryView",
          "when": "view == codexSessionKit.projectMemoryView",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "codexSessionKit.startSessionFromProjectMemory",
        "key": "cmd+alt+.",
        "mac": "cmd+alt+.",
        "when": "editorTextFocus || explorerViewletVisible"
      },
      {
        "command": "codexSessionKit.updateMemoryDocsNow",
        "key": "cmd+alt+u",
        "mac": "cmd+alt+u",
        "when": "editorTextFocus || explorerViewletVisible"
      },
      {
        "command": "codexSessionKit.validateMemoryDocs",
        "key": "cmd+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorTextFocus || explorerViewletVisible"
      },
      {
        "command": "codexSessionKit.finishSessionAndUpdateProjectMemory",
        "key": "cmd+alt+/",
        "mac": "cmd+alt+/",
        "when": "editorTextFocus || explorerViewletVisible"
      },
      {
        "command": "codexSessionKit.initializeProjectMemoryDocs",
        "key": "cmd+alt+shift+.",
        "mac": "cmd+alt+shift+.",
        "when": "editorTextFocus || explorerViewletVisible"
      }
    ],
    "configuration": {
      "title": "AI Session Kit",
      "properties": {
        "codexSessionKit.preferWorkspaceConfig": {
          "type": "boolean",
          "default": true,
          "description": "Prefer .vscode/ai-context.json over extension settings when building prompts and initializing docs."
        },
        "codexSessionKit.docs": {
          "type": "array",
          "default": [
            {
              "path": "docs/project-brief.md",
              "role": "project-brief"
            },
            {
              "path": "docs/current-work.md",
              "role": "current-work"
            },
            {
              "path": "docs/decisions.md",
              "role": "decisions"
            },
            {
              "path": "docs/project-memory-snapshot.md",
              "role": "project-memory-snapshot"
            }
          ],
          "items": {
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "role": {
                "type": "string"
              }
            }
          },
          "description": "Fallback handoff docs used when no .vscode/ai-context.json file exists. Roles help prompts and snapshot generation stay useful even when paths are customized."
        },
        "codexSessionKit.docPaths": {
          "type": "array",
          "default": [
            "docs/project-brief.md",
            "docs/current-work.md",
            "docs/decisions.md",
            "docs/project-memory-snapshot.md"
          ],
          "items": {
            "type": "string"
          },
          "description": "Legacy fallback handoff document paths used when no role-aware docs array is configured."
        }
      }
    }
  }
}
